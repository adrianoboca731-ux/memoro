generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

// === UTENTI ===
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  username      String    @unique
  avatar        String?
  bio           String?
  location      String?
  website       String?
  isPro         Boolean   @default(false) @map("is_pro")
  isPublic      Boolean   @default(true) @map("is_public")
  followerCount Int       @default(0) @map("follower_count")
  followingCount Int      @default(0) @map("following_count")
  photoCount    Int       @default(0) @map("photo_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  photos        Photo[]
  albums        Album[]
  galleries     Gallery[]
  groups        GroupMember[]
  sentMessages  Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  notifications Notification[]
  followers     Follow[]  @relation("UserFollowers")
  following     Follow[]  @relation("UserFollowing")
  favorites     Favorite[]
  settings      UserSettings?

  @@map("users")
}

model UserSettings {
  id                          String   @id @default(cuid())
  userId                      String   @unique @map("user_id")

  // Filtri contenuti adulti (come Flickr)
  safeSearch                  String   @default("moderate") @map("safe_search") // "strict", "moderate", "off"
  showMatureContent           Boolean  @default(false) @map("show_mature_content")
  showRestrictedContent       Boolean  @default(false) @map("show_restricted_content")
  allowMatureUploads          Boolean  @default(false) @map("allow_mature_uploads")

  // Privacy (come Flickr)
  profileVisibility           String   @default("public") @map("profile_visibility") // "public", "friends", "private"
  allowMessages               String   @default("everyone") @map("allow_messages") // "everyone", "contacts", "nobody"
  showEXIF                    Boolean  @default(true) @map("show_exif")
  allowDownloads              Boolean  @default(true) @map("allow_downloads")
  allowComments               Boolean  @default(true) @map("allow_comments")
  showCameraRoll              Boolean  @default(false) @map("show_camera_roll")

  // Notifiche
  emailNotifications          Boolean  @default(true) @map("email_notifications")
  notifyFavorites             Boolean  @default(true) @map("notify_favorites")
  notifyComments              Boolean  @default(true) @map("notify_comments")
  notifyFollows               Boolean  @default(true) @map("notify_follows")
  notifyGroupInvites          Boolean  @default(true) @map("notify_group_invites")
  notifyMessages              Boolean  @default(true) @map("notify_messages")

  // Aspetto
  defaultView                 String   @default("grid") @map("default_view") // "grid", "list", "justified"
  darkMode                    Boolean  @default(false) @map("dark_mode")
  language                    String   @default("it")

  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  user                        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

// === FOTO ===
model Photo {
  id          String    @id @default(cuid())
  title       String
  description String?
  filename    String
  filepath    String
  thumbnail   String?
  mimetype    String
  size        Int
  width       Int?
  height      Int?
  tags        String?
  views       Int       @default(0)
  commentCount Int      @default(0) @map("comment_count")
  favoriteCount Int     @default(0) @map("favorite_count")

  // Contenuti adulti (come Flickr)
  safetyLevel String    @default("safe") @map("safety_level") // "safe", "moderate", "restricted"
  isMature    Boolean   @default(false) @map("is_mature")
  contentRating String? @map("content_rating") // "photo", "art", "screenshot", "illustration"

  userId      String    @map("user_id")
  albumId     String?   @map("album_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  album       Album?    @relation(fields: [albumId], references: [id], onDelete: SetNull)
  comments    Comment[]
  favorites   Favorite[]
  exif        Exif?
  groupPhotos GroupPhoto[]
  galleryItems GalleryItem[]

  @@map("photos")
}

model Exif {
  id            String  @id @default(cuid())
  photoId       String  @unique @map("photo_id")
  camera        String?
  lens          String?
  focalLength   String? @map("focal_length")
  aperture      String?
  shutterSpeed  String? @map("shutter_speed")
  iso           String?
  software      String?
  flash         String?
  photo         Photo   @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@map("exif")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  photoId   String   @map("photo_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([userId, photoId])
  @@map("favorites")
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  authorId  String   @map("author_id")
  photoId   String   @map("photo_id")
  createdAt DateTime @default(now()) @map("created_at")

  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@map("comments")
}

// === ALBUM ===
model Album {
  id          String   @id @default(cuid())
  name        String
  description String?
  cover       String?
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos      Photo[]

  @@map("albums")
}

// === GRUPPI ===
model Group {
  id           String   @id @default(cuid())
  name         String
  description  String?
  cover        String?
  rules        String?
  isPublic     Boolean  @default(true) @map("is_public")
  memberCount  Int      @default(1) @map("member_count")
  photoCount   Int      @default(0) @map("photo_count")
  discussionCount Int   @default(0) @map("discussion_count")
  createdBy    String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  members      GroupMember[]
  photos       GroupPhoto[]
  discussions  GroupDiscussion[]

  @@map("groups")
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  role      String   @default("member")
  joinedAt  DateTime @default(now()) @map("joined_at")

  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupPhoto {
  id        String   @id @default(cuid())
  groupId   String   @map("group_id")
  photoId   String   @map("photo_id")
  addedBy   String   @map("added_by")
  addedAt   DateTime @default(now()) @map("added_at")

  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([groupId, photoId])
  @@map("group_photos")
}

model GroupDiscussion {
  id        String   @id @default(cuid())
  groupId   String   @map("group_id")
  title     String
  body      String
  authorId  String   @map("author_id")
  replyCount Int     @default(0) @map("reply_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  replies   GroupReply[]

  @@map("group_discussions")
}

model GroupReply {
  id           String   @id @default(cuid())
  discussionId String   @map("discussion_id")
  body         String
  authorId     String   @map("author_id")
  createdAt    DateTime @default(now()) @map("created_at")

  discussion   GroupDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@map("group_replies")
}

// === GALLERIE ===
model Gallery {
  id          String   @id @default(cuid())
  name        String
  description String?
  cover       String?
  isPublic    Boolean  @default(true) @map("is_public")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       GalleryItem[]

  @@map("galleries")
}

model GalleryItem {
  id        String   @id @default(cuid())
  galleryId String   @map("gallery_id")
  photoId   String   @map("photo_id")
  note      String?
  addedBy   String   @map("added_by")
  addedAt   DateTime @default(now()) @map("added_at")

  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([galleryId, photoId])
  @@map("gallery_items")
}

// === MESSAGGI ===
model Message {
  id        String   @id @default(cuid())
  fromId    String   @map("from_id")
  toId      String   @map("to_id")
  subject   String
  body      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  sender    User     @relation("SentMessages", fields: [fromId], references: [id], onDelete: Cascade)
  recipient User     @relation("ReceivedMessages", fields: [toId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// === NOTIFICHE ===
model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  link      String?
  fromUserId String? @map("from_user_id")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// === INVITI AI GRUPPI ===
model GroupInvite {
  id        String   @id @default(cuid())
  groupId   String   @map("group_id")
  inviterId String   @map("inviter_id")
  inviteeId String   @map("invitee_id")
  status    String   @default("pending") // "pending", "accepted", "declined"
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([groupId, inviteeId])
  @@map("group_invites")
}
